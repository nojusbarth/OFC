@startuml name Rendering Pipeline Interaction (Controlled Mutability)

' =====================================================
' Rendering Pipeline & JSX Interaction
' React- and Architecture-correct
' =====================================================

skinparam classAttributeIconSize 0
skinparam ranksep 100

' -----------------------------------------------------
' Scene Renderer (JSX)
' -----------------------------------------------------
class SceneRenderer <<JSX Component>> {

  + initCamera()
  + initLight()
}

' -----------------------------------------------------
' JSX Render Objects
' -----------------------------------------------------
class DroneView <<JSX Component>> {
  + props : DroneFrame
  + render() : JSX.Element
}

class PathView <<JSX Component>> {
  + props : PathFrame
  + render() : JSX.Element
}

' -----------------------------------------------------
' State Stores (Render-relevant state)
' -----------------------------------------------------
class DroneStateStore {
  - stateUpdater : StateUpdater<DroneFrame>
  + update(mutator : DroneFrame)
}
'
'  In short: Instead of Set, Get State one Function with
'  mutable object type
'
note right of DroneStateStore
  The 'mutator' parameter is actually a function
  that receives a draft Frame to modify.
  See Glossary entry "Controlled Mutability" for details.
end note

class PathStateStore {
- stateUpdater : StateUpdater<PathFrame>  
+ update(mutator : PathFrame)
}

class LightStateStore {
  - stateUpdater : StateUpdater<LightFrame>
  + update(mutator : LightFrame)
}

' -----------------------------------------------------
' Encapsulated Frames
' -----------------------------------------------------

class DroneFrame {
  + dronePositions : Map<number,Vector3>
  + droneColors : Map<number, string>
}

class PathFrame {
  + pathPositions : Map<number,Vector3>
  + pathColor : Map<number,string>
}

class LightFrame {
  + intensity : number
  + color : string
  + position : Vector3
}

' -----------------------------------------------------
' Subsystems (Logic only, no rendering)
' -----------------------------------------------------
class TimeManager
class SelectionManager
class CollisionManager

' -----------------------------------------------------
' Subsystems modify STATE (not JSX)
' -----------------------------------------------------
TimeManager "1"-- "1" DroneStateStore : edit state >
SelectionManager "1"-- "1" DroneStateStore : edit state >
CollisionManager "1"-- "1" DroneStateStore : edit state >

SelectionManager "1" -- "1" PathStateStore : edit state >
CollisionManager "1" -- "1" PathStateStore : edit state >
TimeManager "1" -- "1" LightStateStore : edit state >

' -----------------------------------------------------
' SceneRenderer reads state and passes props
' -----------------------------------------------------
SceneRenderer "1" -- "1 \n" DroneStateStore : read state >
SceneRenderer "1" -- "1 \n" PathStateStore : read state >
SceneRenderer "1" -- "1 \n" LightStateStore : read state >

SceneRenderer "1" -- "1 \n droneView" DroneView : pass state >
SceneRenderer "1" -- "1 \n pathView" PathView : pass state >

' -----------------------------------------------------
' State Stores update data
' -----------------------------------------------------

DroneStateStore "1" -- "1" DroneFrame : updates > 
PathStateStore "1" -- "1" PathFrame : updates >
LightStateStore "1" -- "1" LightFrame : updates >

@enduml

